---
export interface Props {
  title: string;
  page?: string;
}
const { title, page = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — TitaniumBOE</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#0d1117] text-[#e6edf3] min-h-screen font-mono antialiased">

  <nav class="border-b border-[#30363d] bg-[#161b22] sticky top-0 z-50">
    <div class="max-w-screen-xl mx-auto px-4 flex items-center h-11 gap-6">
      <a href="/" class="text-[#58a6ff] font-semibold text-xs tracking-widest uppercase shrink-0">
        ⬡ TitaniumBOE
      </a>

      <div class="flex items-center gap-0.5">
        <a href="/"         class={`px-3 py-1 rounded text-xs transition-colors ${page==='dashboard' ? 'bg-[#58a6ff]/10 text-[#58a6ff]' : 'text-gray-400 hover:text-gray-200 hover:bg-white/5'}`}>Dashboard</a>
        <a href="/orders"   class={`px-3 py-1 rounded text-xs transition-colors ${page==='orders'    ? 'bg-[#58a6ff]/10 text-[#58a6ff]' : 'text-gray-400 hover:text-gray-200 hover:bg-white/5'}`}>Order Book</a>
        <a href="/trades"   class={`px-3 py-1 rounded text-xs transition-colors ${page==='trades'    ? 'bg-[#58a6ff]/10 text-[#58a6ff]' : 'text-gray-400 hover:text-gray-200 hover:bg-white/5'}`}>Trades</a>
        <a href="/simulator" class={`px-3 py-1 rounded text-xs transition-colors ${page==='simulator' ? 'bg-[#58a6ff]/10 text-[#58a6ff]' : 'text-gray-400 hover:text-gray-200 hover:bg-white/5'}`}>Simulator</a>
      </div>

      <div class="flex-1"></div>

      <div class="flex items-center gap-2 text-xs text-gray-500">
        <span id="ws-dot" class="w-1.5 h-1.5 rounded-full bg-gray-600 transition-colors"></span>
        <span id="ws-label">connecting…</span>
      </div>
    </div>
  </nav>

  <main class="max-w-screen-xl mx-auto px-4 py-5">
    <slot />
  </main>

  <script>
    // Global WebSocket shared across pages
    let ws = null;
    let wsHandlers = [];

    function connectWS() {
      const proto = location.protocol === 'https:' ? 'wss' : 'ws';
      ws = new WebSocket(`${proto}://${location.host}/ws/feed`);

      ws.onopen = () => {
        document.getElementById('ws-dot').style.background = '#3fb950';
        document.getElementById('ws-label').textContent = 'live';
        wsHandlers.forEach(h => h.onopen && h.onopen());
      };

      ws.onclose = () => {
        document.getElementById('ws-dot').style.background = '#f85149';
        document.getElementById('ws-label').textContent = 'reconnecting…';
        setTimeout(connectWS, 3000);
      };

      ws.onerror = () => {
        document.getElementById('ws-dot').style.background = '#d29922';
        document.getElementById('ws-label').textContent = 'error';
      };

      ws.onmessage = (e) => {
        try {
          const msg = JSON.parse(e.data);
          wsHandlers.forEach(h => h.onmessage && h.onmessage(msg));
        } catch (_) {}
      };
    }

    window.wsSubscribe = (symbol) => {
      if (ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({ action: 'subscribe', symbol }));
      }
    };

    window.wsUnsubscribe = (symbol) => {
      if (ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({ action: 'unsubscribe', symbol }));
      }
    };

    window.wsAddHandler = (handler) => {
      wsHandlers.push(handler);
    };

    connectWS();
  </script>

</body>
</html>
