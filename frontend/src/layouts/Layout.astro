---
import '../styles/global.css';
export interface Props {
  title: string;
  page?: string;
}
const { title, page = '' } = Astro.props;

const nav = [
  { label: 'Dashboard',  href: '/',          key: 'dashboard' },
  { label: 'Order Book', href: '/orders',    key: 'orders'    },
  { label: 'Trades',     href: '/trades',    key: 'trades'    },
  { label: 'Bots',       href: '/simulator', key: 'simulator' },
];

const icons: Record<string, string> = {
  dashboard: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
  orders:    `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
  trades:    `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  simulator: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M9 9l2 2 4-4"/></svg>`,
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — TitaniumBOE-Sim</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root { color-scheme: dark; }
    body { font-family: 'Inter', sans-serif; }
    .font-mono { font-family: 'JetBrains Mono', monospace; }
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #1e2a45; border-radius: 2px; }

    #auth-modal {
      display: none;
      position: fixed; inset: 0; z-index: 100;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(4px);
      align-items: center; justify-content: center;
    }
    #auth-modal.open { display: flex; }
  </style>
</head>
<body class="bg-[#070c1a] text-white min-h-screen flex antialiased overflow-hidden">

  <!-- Auth Modal -->
  <div id="auth-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="bg-[#0d1428] border border-[#162035] rounded-2xl w-full max-w-sm mx-4 p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-5">
        <h2 id="modal-title" class="text-base font-semibold text-white">Account Access</h2>
        <button onclick="closeAuthModal()" class="text-gray-600 hover:text-gray-400 transition-colors text-lg leading-none">&times;</button>
      </div>

      <!-- Tabs -->
      <div class="flex gap-1 bg-[#070c1a] rounded-lg p-1 mb-5">
        <button id="tab-login" onclick="switchTab('login')"
          class="flex-1 py-1.5 rounded-md text-xs font-semibold transition-all bg-violet-600/25 text-violet-300 border border-violet-500/30">
          Login
        </button>
        <button id="tab-register" onclick="switchTab('register')"
          class="flex-1 py-1.5 rounded-md text-xs font-semibold transition-all text-gray-500 hover:text-gray-300">
          Register
        </button>
      </div>

      <!-- Error message -->
      <div id="auth-error" class="hidden mb-4 px-3 py-2 bg-red-500/10 border border-red-500/20 rounded-lg text-xs text-red-400"></div>

      <!-- Login form -->
      <form id="form-login" onsubmit="submitLogin(event)" class="space-y-3">
        <div>
          <label class="block text-[11px] text-gray-500 uppercase tracking-wider mb-1.5">Username</label>
          <input id="login-user" type="text" maxlength="4" placeholder="TRD1"
            class="w-full bg-[#070c1a] border border-[#162035] rounded-lg px-3 py-2 text-sm text-white placeholder-gray-700 focus:outline-none focus:border-violet-500/50 transition-colors font-mono" />
        </div>
        <div>
          <label class="block text-[11px] text-gray-500 uppercase tracking-wider mb-1.5">Password</label>
          <input id="login-pass" type="password" maxlength="10" placeholder="••••••••••"
            class="w-full bg-[#070c1a] border border-[#162035] rounded-lg px-3 py-2 text-sm text-white placeholder-gray-700 focus:outline-none focus:border-violet-500/50 transition-colors" />
        </div>
        <button type="submit" id="btn-login-submit"
          class="w-full py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-lg transition-colors mt-1">
          Sign In
        </button>
        <p class="text-[11px] text-gray-600 text-center">Demo: TRD1 / Pass1234!</p>
      </form>

      <!-- Register form -->
      <form id="form-register" onsubmit="submitRegister(event)" class="space-y-3 hidden">
        <div>
          <label class="block text-[11px] text-gray-500 uppercase tracking-wider mb-1.5">Username <span class="text-gray-700">(1-4 chars)</span></label>
          <input id="reg-user" type="text" maxlength="4" placeholder="MYID"
            class="w-full bg-[#070c1a] border border-[#162035] rounded-lg px-3 py-2 text-sm text-white placeholder-gray-700 focus:outline-none focus:border-violet-500/50 transition-colors font-mono" />
        </div>
        <div>
          <label class="block text-[11px] text-gray-500 uppercase tracking-wider mb-1.5">Password <span class="text-gray-700">(6-10 chars)</span></label>
          <input id="reg-pass" type="password" maxlength="10" placeholder="••••••••••"
            class="w-full bg-[#070c1a] border border-[#162035] rounded-lg px-3 py-2 text-sm text-white placeholder-gray-700 focus:outline-none focus:border-violet-500/50 transition-colors" />
        </div>
        <button type="submit" id="btn-reg-submit"
          class="w-full py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold rounded-lg transition-colors mt-1">
          Create Account
        </button>
      </form>
    </div>
  </div>

  <!-- Sidebar -->
  <aside class="w-52 shrink-0 bg-[#090e1e] border-r border-[#162035] flex flex-col h-screen sticky top-0 z-30">

    <!-- Logo -->
    <div class="px-4 py-4 border-b border-[#162035]">
      <div class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-500 to-purple-700 flex items-center justify-center text-base font-bold shrink-0">◈</div>
        <div class="min-w-0">
          <div class="text-sm font-semibold text-white leading-tight truncate">TitaniumBOE-Sim</div>
          <div class="text-[10px] text-violet-400/60 leading-tight">Cboe BOE Protocol</div>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 py-3 px-2 space-y-0.5 overflow-y-auto">
      {nav.map(item => (
        <a
          href={item.href}
          class={`flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium transition-all ${
            page === item.key
              ? 'bg-violet-600/20 text-violet-300 border border-violet-500/25 shadow-sm'
              : 'text-gray-400 hover:text-gray-200 hover:bg-white/[0.04]'
          }`}
        >
          <span class={`shrink-0 ${page === item.key ? 'text-violet-400' : 'text-gray-600'}`}
            set:html={icons[item.key]} />
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Bottom: user + status -->
    <div class="px-3 py-3 border-t border-[#162035] space-y-2">
      <!-- Auth status -->
      <div id="auth-status-bar" class="bg-[#0d1428] rounded-lg px-3 py-2.5">
        <div class="text-[10px] text-gray-600 uppercase tracking-widest mb-1.5">Account</div>
        <div class="flex items-center justify-between gap-1">
          <span id="auth-username" class="text-xs text-gray-500 font-mono truncate">Not logged in</span>
          <button id="auth-action-btn" onclick="handleAuthAction()"
            class="text-[10px] px-2 py-0.5 rounded font-semibold transition-all bg-violet-600/20 text-violet-400 border border-violet-500/25 hover:bg-violet-600/35 shrink-0">
            Login
          </button>
        </div>
      </div>

      <div class="bg-[#0d1428] rounded-lg px-3 py-2.5">
        <div class="text-[10px] text-gray-600 uppercase tracking-widest mb-1.5">BOE Protocol</div>
        <div class="flex items-center gap-2 text-xs">
          <span id="ws-dot" class="w-1.5 h-1.5 rounded-full bg-gray-600 transition-colors shrink-0"></span>
          <span id="ws-label" class="text-gray-500">Connecting…</span>
        </div>
      </div>
      <div class="bg-[#0d1428] rounded-lg px-3 py-2.5">
        <div class="text-[10px] text-gray-600 uppercase tracking-widest mb-1.5">Trading Bots</div>
        <div class="flex items-center justify-between text-xs">
          <span id="sidebar-bots-label" class="text-gray-500">—</span>
          <span id="sidebar-bots-state" class="text-[10px] px-1.5 py-0.5 rounded bg-gray-700/50 text-gray-500">—</span>
        </div>
      </div>
    </div>
  </aside>

  <!-- Main content -->
  <div class="flex-1 flex flex-col min-w-0 h-screen overflow-y-auto">
    <slot />
  </div>

  <script>
    // ── Auth state ────────────────────────────────────────────────────────────
    (window as any).getAuthHeader = (): string | null => {
      const u = sessionStorage.getItem('auth_user');
      const p = sessionStorage.getItem('auth_pass');
      if (!u || !p) return null;
      return 'Basic ' + btoa(`${u}:${p}`);
    };

    (window as any).getAuthUser = (): string | null => {
      return sessionStorage.getItem('auth_user');
    };

    function isLoggedIn(): boolean {
      return !!sessionStorage.getItem('auth_user');
    }

    function updateAuthBar() {
      const usernameEl = document.getElementById('auth-username')!;
      const btnEl = document.getElementById('auth-action-btn')!;
      const user = sessionStorage.getItem('auth_user');
      if (user) {
        usernameEl.textContent = user;
        (usernameEl as HTMLElement).style.color = '#a78bfa';
        btnEl.textContent = 'Logout';
        btnEl.style.cssText = 'background:rgba(239,68,68,0.12);color:#f87171;border-color:rgba(239,68,68,0.25)';
      } else {
        usernameEl.textContent = 'Not logged in';
        (usernameEl as HTMLElement).style.color = '';
        btnEl.textContent = 'Login';
        btnEl.style.cssText = '';
      }
    }

    (window as any).handleAuthAction = () => {
      if (isLoggedIn()) {
        sessionStorage.removeItem('auth_user');
        sessionStorage.removeItem('auth_pass');
        updateAuthBar();
        window.location.reload();
      } else {
        openAuthModal();
      }
    };

    // ── Modal ─────────────────────────────────────────────────────────────────
    (window as any).openAuthModal = () => {
      document.getElementById('auth-modal')!.classList.add('open');
      document.getElementById('auth-error')!.classList.add('hidden');
      (document.getElementById('login-user') as HTMLInputElement).value = '';
      (document.getElementById('login-pass') as HTMLInputElement).value = '';
    };

    (window as any).closeAuthModal = () => {
      document.getElementById('auth-modal')!.classList.remove('open');
    };

    document.getElementById('auth-modal')!.addEventListener('click', (e) => {
      if (e.target === document.getElementById('auth-modal')) (window as any).closeAuthModal();
    });

    (window as any).switchTab = (tab: 'login' | 'register') => {
      const loginForm = document.getElementById('form-login')!;
      const regForm   = document.getElementById('form-register')!;
      const tabLogin  = document.getElementById('tab-login')!;
      const tabReg    = document.getElementById('tab-register')!;
      const errEl     = document.getElementById('auth-error')!;
      errEl.classList.add('hidden');

      if (tab === 'login') {
        loginForm.classList.remove('hidden');
        regForm.classList.add('hidden');
        tabLogin.style.cssText = 'background:rgba(124,58,237,0.25);color:#c4b5fd;border:1px solid rgba(124,58,237,0.3)';
        tabReg.style.cssText   = '';
      } else {
        loginForm.classList.add('hidden');
        regForm.classList.remove('hidden');
        tabReg.style.cssText   = 'background:rgba(124,58,237,0.25);color:#c4b5fd;border:1px solid rgba(124,58,237,0.3)';
        tabLogin.style.cssText = '';
      }
    };

    function showAuthError(msg: string) {
      const el = document.getElementById('auth-error')!;
      el.textContent = msg;
      el.classList.remove('hidden');
    }

    (window as any).submitLogin = async (e: Event) => {
      e.preventDefault();
      const user = (document.getElementById('login-user') as HTMLInputElement).value.trim();
      const pass = (document.getElementById('login-pass') as HTMLInputElement).value;
      const btn  = document.getElementById('btn-login-submit') as HTMLButtonElement;

      if (!user || !pass) { showAuthError('Username and password are required'); return; }

      btn.disabled = true;
      btn.textContent = 'Signing in…';

      try {
        const r = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: user, password: pass })
        });
        const d = await r.json();
        if (r.ok && d.success) {
          sessionStorage.setItem('auth_user', d.data.username);
          sessionStorage.setItem('auth_pass', pass);
          (window as any).closeAuthModal();
          updateAuthBar();
          window.location.reload();
        } else {
          showAuthError(d.error ?? 'Login failed');
        }
      } catch (_) {
        showAuthError('Connection error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Sign In';
      }
    };

    (window as any).submitRegister = async (e: Event) => {
      e.preventDefault();
      const user = (document.getElementById('reg-user') as HTMLInputElement).value.trim().toUpperCase();
      const pass = (document.getElementById('reg-pass') as HTMLInputElement).value;
      const btn  = document.getElementById('btn-reg-submit') as HTMLButtonElement;

      if (!user || !pass) { showAuthError('All fields are required'); return; }

      btn.disabled = true;
      btn.textContent = 'Creating…';

      try {
        const r = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: user, password: pass })
        });
        const d = await r.json();
        if (r.ok && d.success) {
          sessionStorage.setItem('auth_user', d.data.username);
          sessionStorage.setItem('auth_pass', pass);
          (window as any).closeAuthModal();
          updateAuthBar();
          window.location.reload();
        } else {
          showAuthError(d.error ?? 'Registration failed');
        }
      } catch (_) {
        showAuthError('Connection error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Create Account';
      }
    };

    updateAuthBar();

    // ── WebSocket ─────────────────────────────────────────────────────────────
    let ws: WebSocket | null = null;
    const wsHandlers: any[] = [];

    function connectWS() {
      const proto = location.protocol === 'https:' ? 'wss' : 'ws';
      ws = new WebSocket(`${proto}://${location.host}/ws/feed`);

      ws.onopen = () => {
        const dot = document.getElementById('ws-dot');
        const lbl = document.getElementById('ws-label');
        if (dot) dot.style.background = '#22c55e';
        if (lbl) { lbl.textContent = 'Connected'; (lbl as HTMLElement).style.color = '#22c55e'; }
        wsHandlers.forEach(h => h.onopen?.());
      };

      ws.onclose = () => {
        const dot = document.getElementById('ws-dot');
        const lbl = document.getElementById('ws-label');
        if (dot) dot.style.background = '#ef4444';
        if (lbl) { lbl.textContent = 'Reconnecting…'; (lbl as HTMLElement).style.color = '#6b7280'; }
        setTimeout(connectWS, 3000);
      };

      ws.onerror = () => {
        const dot = document.getElementById('ws-dot');
        if (dot) dot.style.background = '#f59e0b';
      };

      ws.onmessage = (e) => {
        try {
          const msg = JSON.parse(e.data);
          wsHandlers.forEach(h => h.onmessage?.(msg));
        } catch (_) {}
      };
    }

    (window as any).wsSubscribe = (symbol: string) => {
      if (ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({ action: 'subscribe', symbol }));
      }
    };

    (window as any).wsUnsubscribe = (symbol: string) => {
      if (ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({ action: 'unsubscribe', symbol }));
      }
    };

    (window as any).wsAddHandler = (handler: any) => {
      wsHandlers.push(handler);
    };

    async function fetchSidebarSim() {
      try {
        const r = await fetch('/api/simulator/status');
        const d = await r.json();
        const st = d.data ?? d;
        const running = st.running ?? st.isRunning ?? false;
        const bots = st.activeBots ?? st.totalBots ?? '—';
        const lbl = document.getElementById('sidebar-bots-label');
        const state = document.getElementById('sidebar-bots-state');
        if (lbl) lbl.textContent = `${bots} active`;
        if (state) {
          state.textContent = running ? 'Running' : 'Stopped';
          state.style.background = running ? 'rgba(34,197,94,0.15)' : 'rgba(107,114,128,0.2)';
          state.style.color = running ? '#22c55e' : '#6b7280';
        }
      } catch (_) {}
    }

    fetchSidebarSim();
    setInterval(fetchSidebarSim, 5000);
    connectWS();
  </script>

</body>
</html>
