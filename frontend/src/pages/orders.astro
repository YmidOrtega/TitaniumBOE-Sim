---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Order Book" page="orders">

  <!-- Symbol tabs -->
  <div class="flex items-center gap-1.5 mb-4 flex-wrap">
    {['AAPL','MSFT','GOOGL','GOOG','AMZN','META','TSLA','NFLX'].map(s => (
      <button
        data-symbol={s}
        onclick={`selectSymbol('${s}')`}
        class="symbol-tab px-3 py-1 rounded text-xs border border-[#30363d] text-gray-400 hover:text-gray-200 hover:border-[#58a6ff]/40 transition-colors"
      >{s}</button>
    ))}
    <span class="ml-auto text-xs text-gray-500" id="book-timestamp">—</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

    <!-- Order Book -->
    <div class="lg:col-span-2 bg-[#161b22] border border-[#30363d] rounded overflow-hidden">
      <!-- Asks -->
      <div class="border-b border-[#30363d]">
        <div class="flex justify-between px-4 py-2 text-[10px] text-gray-500 uppercase tracking-wider">
          <span>Price</span>
          <span>Orders</span>
          <span>Qty</span>
          <span>Total</span>
        </div>
        <div id="asks-body" class="flex flex-col-reverse" style="min-height:220px">
          <div class="px-4 py-2 text-xs text-gray-600 text-center">No asks</div>
        </div>
      </div>

      <!-- Spread -->
      <div class="px-4 py-2.5 border-b border-[#30363d] bg-[#0d1117]/40 flex items-center justify-between">
        <div class="text-[10px] text-gray-500">Last Trade</div>
        <div class="text-sm font-semibold" id="last-trade-price">—</div>
        <div class="text-[10px] text-gray-500">Spread</div>
        <div class="text-xs" id="spread-value">—</div>
        <div class="text-[10px] text-gray-500">Mid</div>
        <div class="text-xs" id="mid-value">—</div>
      </div>

      <!-- Bids -->
      <div>
        <div class="flex justify-between px-4 py-2 text-[10px] text-gray-500 uppercase tracking-wider">
          <span>Price</span>
          <span>Orders</span>
          <span>Qty</span>
          <span>Total</span>
        </div>
        <div id="bids-body" style="min-height:220px">
          <div class="px-4 py-2 text-xs text-gray-600 text-center">No bids</div>
        </div>
      </div>
    </div>

    <!-- Symbol info + stats -->
    <div class="flex flex-col gap-4">

      <div class="bg-[#161b22] border border-[#30363d] rounded p-4">
        <div class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-3">
          <span id="selected-symbol-label">Select a symbol</span>
        </div>
        <div class="space-y-2 text-xs">
          <div class="flex justify-between">
            <span class="text-gray-500">Best Bid</span>
            <span class="text-[#3fb950] font-mono" id="info-best-bid">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Best Ask</span>
            <span class="text-[#f85149] font-mono" id="info-best-ask">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Total Bid Qty</span>
            <span class="text-gray-300" id="info-bid-qty">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Total Ask Qty</span>
            <span class="text-gray-300" id="info-ask-qty">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Last Price</span>
            <span class="text-gray-300 font-mono" id="info-last">—</span>
          </div>
        </div>
      </div>

      <div class="bg-[#161b22] border border-[#30363d] rounded p-4">
        <div class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-3">Recent Trades</div>
        <div id="symbol-trades" class="space-y-1.5 text-xs overflow-y-auto" style="max-height:300px">
          <div class="text-gray-600">Waiting…</div>
        </div>
      </div>

    </div>
  </div>

</Layout>

<script>
  const SYMBOLS = ['AAPL','MSFT','GOOGL','GOOG','AMZN','META','TSLA','NFLX'];
  let currentSymbol = null;
  let symbolTrades = {};

  // Read symbol from URL
  const urlSym = new URLSearchParams(location.search).get('symbol');
  if (urlSym && SYMBOLS.includes(urlSym)) {
    setTimeout(() => selectSymbol(urlSym), 100);
  } else {
    setTimeout(() => selectSymbol('AAPL'), 100);
  }

  window.selectSymbol = function(sym) {
    if (currentSymbol) window.wsUnsubscribe(currentSymbol);

    currentSymbol = sym;
    window.wsSubscribe(sym);

    // Update tab styles
    document.querySelectorAll('.symbol-tab').forEach(t => {
      const active = t.dataset.symbol === sym;
      t.className = `symbol-tab px-3 py-1 rounded text-xs border transition-colors ${
        active
          ? 'border-[#58a6ff]/60 bg-[#58a6ff]/10 text-[#58a6ff]'
          : 'border-[#30363d] text-gray-400 hover:text-gray-200 hover:border-[#58a6ff]/40'
      }`;
    });

    document.getElementById('selected-symbol-label').textContent = sym;

    // Reset book display
    resetBook();

    // Show cached trades
    renderSymbolTrades(sym);

    // Update URL without reload
    history.replaceState(null, '', `/orders?symbol=${sym}`);
  };

  function resetBook() {
    document.getElementById('asks-body').innerHTML = '<div class="px-4 py-2 text-xs text-gray-600 text-center">Waiting…</div>';
    document.getElementById('bids-body').innerHTML = '<div class="px-4 py-2 text-xs text-gray-600 text-center">Waiting…</div>';
    document.getElementById('last-trade-price').textContent = '—';
    document.getElementById('spread-value').textContent = '—';
    document.getElementById('mid-value').textContent = '—';
    document.getElementById('info-best-bid').textContent = '—';
    document.getElementById('info-best-ask').textContent = '—';
    document.getElementById('info-bid-qty').textContent = '—';
    document.getElementById('info-ask-qty').textContent = '—';
    document.getElementById('info-last').textContent = '—';
  }

  function renderBook(msg) {
    const bids = msg.bids ?? [];
    const asks = msg.asks ?? [];

    const maxQty = Math.max(
      ...bids.map(l => l.quantity ?? 0),
      ...asks.map(l => l.quantity ?? 0),
      1
    );

    // Asks (ascending — lowest ask nearest the spread)
    const asksEl = document.getElementById('asks-body');
    if (asks.length === 0) {
      asksEl.innerHTML = '<div class="px-4 py-2 text-xs text-gray-600 text-center">No asks</div>';
    } else {
      asksEl.innerHTML = asks.map(l => {
        const pct = ((l.quantity ?? 0) / maxQty * 100).toFixed(1);
        const price = parseFloat(l.price ?? 0).toFixed(4);
        return `
        <div class="flex justify-between items-center px-4 py-1 relative group hover:bg-white/[0.02]" style="background:linear-gradient(to left,rgba(248,81,73,0.08) ${pct}%,transparent ${pct}%)">
          <span class="font-mono text-[#f85149] text-xs z-10">${price}</span>
          <span class="text-gray-500 text-xs z-10">${l.orderCount ?? 0}</span>
          <span class="text-gray-300 text-xs z-10">${l.quantity ?? 0}</span>
          <span class="text-gray-500 text-xs z-10">${((l.quantity??0)*parseFloat(l.price??0)).toFixed(0)}</span>
        </div>`;
      }).join('');
    }

    // Bids (descending — highest bid nearest the spread)
    const bidsEl = document.getElementById('bids-body');
    if (bids.length === 0) {
      bidsEl.innerHTML = '<div class="px-4 py-2 text-xs text-gray-600 text-center">No bids</div>';
    } else {
      bidsEl.innerHTML = bids.map(l => {
        const pct = ((l.quantity ?? 0) / maxQty * 100).toFixed(1);
        const price = parseFloat(l.price ?? 0).toFixed(4);
        return `
        <div class="flex justify-between items-center px-4 py-1 relative hover:bg-white/[0.02]" style="background:linear-gradient(to left,rgba(63,185,80,0.08) ${pct}%,transparent ${pct}%)">
          <span class="font-mono text-[#3fb950] text-xs z-10">${price}</span>
          <span class="text-gray-500 text-xs z-10">${l.orderCount ?? 0}</span>
          <span class="text-gray-300 text-xs z-10">${l.quantity ?? 0}</span>
          <span class="text-gray-500 text-xs z-10">${((l.quantity??0)*parseFloat(l.price??0)).toFixed(0)}</span>
        </div>`;
      }).join('');
    }

    // Spread / mid
    const bestBid = bids[0]  ? parseFloat(bids[0].price)  : null;
    const bestAsk = asks[asks.length-1] ? parseFloat(asks[asks.length-1].price) : null;

    if (bestBid !== null) document.getElementById('info-best-bid').textContent = bestBid.toFixed(4);
    if (bestAsk !== null) document.getElementById('info-best-ask').textContent = bestAsk.toFixed(4);

    if (bestBid && bestAsk) {
      const spread = (bestAsk - bestBid).toFixed(4);
      const mid    = ((bestBid + bestAsk) / 2).toFixed(4);
      document.getElementById('spread-value').textContent = spread;
      document.getElementById('mid-value').textContent    = mid;
    }

    const bidQty = bids.reduce((s,l) => s+(l.quantity??0), 0);
    const askQty = asks.reduce((s,l) => s+(l.quantity??0), 0);
    document.getElementById('info-bid-qty').textContent = bidQty;
    document.getElementById('info-ask-qty').textContent = askQty;

    if (msg.lastTradePrice) {
      const p = parseFloat(msg.lastTradePrice).toFixed(4);
      document.getElementById('last-trade-price').textContent = p;
      document.getElementById('info-last').textContent = p;
    }

    document.getElementById('book-timestamp').textContent = new Date().toLocaleTimeString('en-US', { hour12: false });
  }

  function renderSymbolTrades(sym) {
    const trades = (symbolTrades[sym] ?? []).slice(0, 40);
    const el = document.getElementById('symbol-trades');
    if (trades.length === 0) {
      el.innerHTML = '<div class="text-gray-600">No trades yet</div>';
      return;
    }
    el.innerHTML = trades.map(t => {
      const price = parseFloat(t.price ?? 0).toFixed(4);
      const time  = new Date(t.timestamp ?? Date.now()).toLocaleTimeString('en-US', { hour12: false });
      return `<div class="flex justify-between items-center py-0.5 border-b border-[#30363d]/30">
        <span class="text-gray-500">${time}</span>
        <span class="font-mono text-[#3fb950]">${price}</span>
        <span class="text-gray-400">${t.quantity ?? '—'}</span>
      </div>`;
    }).join('');
  }

  window.wsAddHandler({
    onopen() {
      if (currentSymbol) window.wsSubscribe(currentSymbol);
    },
    onmessage(msg) {
      if (msg.type === 'orderbook' && msg.symbol === currentSymbol) {
        renderBook(msg);
      }
      if (msg.type === 'trade') {
        if (!symbolTrades[msg.symbol]) symbolTrades[msg.symbol] = [];
        symbolTrades[msg.symbol].unshift(msg);
        if (symbolTrades[msg.symbol].length > 100) symbolTrades[msg.symbol].pop();
        if (msg.symbol === currentSymbol) renderSymbolTrades(currentSymbol);
      }
    }
  });
</script>
