---
import Layout from '../layouts/Layout.astro';
const SYMBOLS = ['AAPL','MSFT','GOOGL','GOOG','AMZN','META','TSLA','NFLX'];
---
<Layout title="Order Book" page="orders">

  <!-- Page header -->
  <div class="border-b border-[#162035] bg-[#090e1e] px-6 py-3 flex items-center justify-between shrink-0">
    <div>
      <h1 class="text-sm font-semibold text-white">Order Book</h1>
      <p class="text-[11px] text-gray-600">Real-time bid/ask depth per symbol</p>
    </div>
    <div class="flex items-center gap-2">
      {SYMBOLS.map(s => (
        <button
          data-symbol={s}
          onclick={`selectSymbol('${s}')`}
          class="symbol-tab px-3 py-1.5 rounded-lg text-[11px] font-medium border border-[#1e2a45] text-gray-500 hover:text-gray-300 hover:border-violet-500/30 transition-all"
        >{s}</button>
      ))}
    </div>
    <span class="text-[10px] text-gray-600 font-mono" id="book-timestamp">—</span>
  </div>

  <!-- Content -->
  <div class="p-5 flex gap-4" style="height:calc(100vh - 57px)">

    <!-- Order Book main -->
    <div class="flex-1 bg-[#0d1428] border border-[#162035] rounded-xl overflow-hidden flex flex-col">
      <!-- Asks -->
      <div class="flex-1 overflow-y-auto flex flex-col-reverse">
        <div class="sticky bottom-0 bg-[#0d1428] grid grid-cols-4 px-5 py-2 text-[10px] text-gray-600 uppercase tracking-wider border-b border-[#162035]/60">
          <span>Price</span>
          <span class="text-right">Orders</span>
          <span class="text-right">Qty</span>
          <span class="text-right">Total</span>
        </div>
        <div id="asks-body" class="flex flex-col-reverse" style="min-height:200px">
          <div class="px-5 py-10 text-center text-xs text-gray-600">Select a symbol</div>
        </div>
      </div>

      <!-- Spread row -->
      <div class="px-5 py-2.5 bg-[#080d1a] border-y border-[#162035] flex items-center justify-between text-[11px]">
        <div class="flex items-center gap-3">
          <span class="text-gray-600">Last Trade</span>
          <span class="font-mono font-semibold text-white" id="last-trade-price">—</span>
        </div>
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2">
            <span class="text-gray-600">Spread</span>
            <span class="font-mono text-violet-300 font-semibold" id="spread-value">—</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-gray-600">Mid</span>
            <span class="font-mono text-gray-300" id="mid-value">—</span>
          </div>
        </div>
      </div>

      <!-- Bids -->
      <div class="flex-1 overflow-y-auto">
        <div class="sticky top-0 bg-[#0d1428] grid grid-cols-4 px-5 py-2 text-[10px] text-gray-600 uppercase tracking-wider border-b border-[#162035]/60">
          <span>Price</span>
          <span class="text-right">Orders</span>
          <span class="text-right">Qty</span>
          <span class="text-right">Total</span>
        </div>
        <div id="bids-body" style="min-height:200px">
          <div class="px-5 py-10 text-center text-xs text-gray-600">Select a symbol</div>
        </div>
      </div>
    </div>

    <!-- Right panel -->
    <div class="w-60 flex flex-col gap-3 shrink-0">

      <!-- Symbol info -->
      <div class="bg-[#0d1428] border border-[#162035] rounded-xl p-4">
        <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-3">
          <span id="selected-symbol-label">Select a symbol</span>
        </div>
        <div class="space-y-2.5 text-xs">
          <div class="flex justify-between">
            <span class="text-gray-600">Best Bid</span>
            <span class="text-emerald-400 font-mono font-semibold" id="info-best-bid">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Best Ask</span>
            <span class="text-rose-400 font-mono font-semibold" id="info-best-ask">—</span>
          </div>
          <div class="w-full h-px bg-[#162035]"></div>
          <div class="flex justify-between">
            <span class="text-gray-600">Bid Qty</span>
            <span class="text-gray-300 font-mono" id="info-bid-qty">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Ask Qty</span>
            <span class="text-gray-300 font-mono" id="info-ask-qty">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Last Price</span>
            <span class="text-gray-300 font-mono" id="info-last">—</span>
          </div>
        </div>
      </div>

      <!-- Recent trades for symbol -->
      <div class="bg-[#0d1428] border border-[#162035] rounded-xl overflow-hidden flex-1">
        <div class="px-4 py-3 border-b border-[#162035]">
          <span class="text-[10px] text-gray-600 uppercase tracking-widest font-medium">Recent Trades</span>
        </div>
        <div id="symbol-trades" class="overflow-y-auto p-3 space-y-1" style="max-height:calc(100% - 41px)">
          <div class="text-xs text-gray-600">Waiting…</div>
        </div>
      </div>

    </div>
  </div>

</Layout>

<script>
  const SYMBOLS = ['AAPL','MSFT','GOOGL','GOOG','AMZN','META','TSLA','NFLX'];
  let currentSymbol: string | null = null;
  let symbolTrades: Record<string, any[]> = {};

  const urlSym = new URLSearchParams(location.search).get('symbol');
  if (urlSym && SYMBOLS.includes(urlSym)) {
    setTimeout(() => selectSymbol(urlSym), 100);
  } else {
    setTimeout(() => selectSymbol('AAPL'), 100);
  }

  (window as any).selectSymbol = function(sym: string) {
    if (currentSymbol) (window as any).wsUnsubscribe(currentSymbol);
    currentSymbol = sym;
    (window as any).wsSubscribe(sym);

    document.querySelectorAll<HTMLElement>('.symbol-tab').forEach(t => {
      const active = t.dataset.symbol === sym;
      t.className = `symbol-tab px-3 py-1.5 rounded-lg text-[11px] font-medium border transition-all ${
        active
          ? 'border-violet-500/40 bg-violet-600/15 text-violet-300'
          : 'border-[#1e2a45] text-gray-500 hover:text-gray-300 hover:border-violet-500/30'
      }`;
    });

    document.getElementById('selected-symbol-label')!.textContent = sym;
    resetBook();
    renderSymbolTrades(sym);
    history.replaceState(null, '', `/orders?symbol=${sym}`);
  };

  function resetBook() {
    document.getElementById('asks-body')!.innerHTML = '<div class="px-5 py-8 text-center text-xs text-gray-600">Waiting…</div>';
    document.getElementById('bids-body')!.innerHTML = '<div class="px-5 py-8 text-center text-xs text-gray-600">Waiting…</div>';
    ['last-trade-price','spread-value','mid-value','info-best-bid','info-best-ask',
     'info-bid-qty','info-ask-qty','info-last'].forEach(id => {
      document.getElementById(id)!.textContent = '—';
    });
  }

  function renderBook(msg: any) {
    const bids = msg.bids ?? [];
    const asks = msg.asks ?? [];
    const maxQty = Math.max(...bids.map((l: any) => l.quantity ?? 0), ...asks.map((l: any) => l.quantity ?? 0), 1);

    const asksEl = document.getElementById('asks-body')!;
    if (asks.length === 0) {
      asksEl.innerHTML = '<div class="px-5 py-6 text-center text-xs text-gray-600">No asks</div>';
    } else {
      asksEl.innerHTML = asks.map((l: any) => {
        const pct = ((l.quantity ?? 0) / maxQty * 100).toFixed(1);
        const price = parseFloat(l.price ?? 0).toFixed(4);
        return `<div class="grid grid-cols-4 items-center px-5 py-1.5 relative group hover:bg-white/[0.02] text-xs"
          style="background:linear-gradient(to left,rgba(248,113,113,0.07) ${pct}%,transparent ${pct}%)">
          <span class="font-mono text-rose-400 z-10">${price}</span>
          <span class="text-right text-gray-600 z-10">${l.orderCount ?? 0}</span>
          <span class="text-right text-gray-300 z-10 font-mono">${l.quantity ?? 0}</span>
          <span class="text-right text-gray-600 z-10 font-mono">${((l.quantity??0)*parseFloat(l.price??0)).toFixed(0)}</span>
        </div>`;
      }).join('');
    }

    const bidsEl = document.getElementById('bids-body')!;
    if (bids.length === 0) {
      bidsEl.innerHTML = '<div class="px-5 py-6 text-center text-xs text-gray-600">No bids</div>';
    } else {
      bidsEl.innerHTML = bids.map((l: any) => {
        const pct = ((l.quantity ?? 0) / maxQty * 100).toFixed(1);
        const price = parseFloat(l.price ?? 0).toFixed(4);
        return `<div class="grid grid-cols-4 items-center px-5 py-1.5 relative hover:bg-white/[0.02] text-xs"
          style="background:linear-gradient(to left,rgba(34,197,94,0.07) ${pct}%,transparent ${pct}%)">
          <span class="font-mono text-emerald-400 z-10">${price}</span>
          <span class="text-right text-gray-600 z-10">${l.orderCount ?? 0}</span>
          <span class="text-right text-gray-300 z-10 font-mono">${l.quantity ?? 0}</span>
          <span class="text-right text-gray-600 z-10 font-mono">${((l.quantity??0)*parseFloat(l.price??0)).toFixed(0)}</span>
        </div>`;
      }).join('');
    }

    const bestBid = bids[0] ? parseFloat(bids[0].price) : null;
    const bestAsk = asks[asks.length-1] ? parseFloat(asks[asks.length-1].price) : null;
    if (bestBid !== null) document.getElementById('info-best-bid')!.textContent = bestBid.toFixed(4);
    if (bestAsk !== null) document.getElementById('info-best-ask')!.textContent = bestAsk.toFixed(4);
    if (bestBid && bestAsk) {
      document.getElementById('spread-value')!.textContent = (bestAsk - bestBid).toFixed(4);
      document.getElementById('mid-value')!.textContent = ((bestBid + bestAsk) / 2).toFixed(4);
    }
    const bidQty = bids.reduce((s: number, l: any) => s + (l.quantity ?? 0), 0);
    const askQty = asks.reduce((s: number, l: any) => s + (l.quantity ?? 0), 0);
    document.getElementById('info-bid-qty')!.textContent = bidQty.toLocaleString();
    document.getElementById('info-ask-qty')!.textContent = askQty.toLocaleString();
    if (msg.lastTradePrice) {
      const p = parseFloat(msg.lastTradePrice).toFixed(4);
      document.getElementById('last-trade-price')!.textContent = p;
      document.getElementById('info-last')!.textContent = p;
    }
    document.getElementById('book-timestamp')!.textContent = new Date().toLocaleTimeString('en-US', { hour12: false });
  }

  function renderSymbolTrades(sym: string) {
    const trades = (symbolTrades[sym] ?? []).slice(0, 50);
    const el = document.getElementById('symbol-trades')!;
    if (trades.length === 0) {
      el.innerHTML = '<div class="text-xs text-gray-600">No trades yet</div>';
      return;
    }
    el.innerHTML = trades.map((t: any) => {
      const price = parseFloat(t.price ?? 0).toFixed(4);
      const time = new Date(t.timestamp ?? Date.now()).toLocaleTimeString('en-US', { hour12: false });
      return `<div class="flex justify-between items-center py-1 border-b border-[#162035]/40 text-[11px]">
        <span class="text-gray-600 font-mono">${time}</span>
        <span class="font-mono text-emerald-400 font-medium">${price}</span>
        <span class="text-gray-500 font-mono">${t.quantity ?? '—'}</span>
      </div>`;
    }).join('');
  }

  (window as any).wsAddHandler({
    onopen() { if (currentSymbol) (window as any).wsSubscribe(currentSymbol); },
    onmessage(msg: any) {
      if (msg.type === 'orderbook' && msg.symbol === currentSymbol) renderBook(msg);
      if (msg.type === 'trade') {
        if (!symbolTrades[msg.symbol]) symbolTrades[msg.symbol] = [];
        symbolTrades[msg.symbol].unshift(msg);
        if (symbolTrades[msg.symbol].length > 100) symbolTrades[msg.symbol].pop();
        if (msg.symbol === currentSymbol) renderSymbolTrades(currentSymbol);
      }
    }
  });
</script>
