---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Bots" page="simulator">

  <!-- Page header -->
  <div class="border-b border-[#162035] bg-[#090e1e] px-6 py-3 flex items-center justify-between shrink-0">
    <div>
      <h1 class="text-sm font-semibold text-white">Trading Bots</h1>
      <p class="text-[11px] text-gray-600">Manage automated trading strategies</p>
    </div>
    <div class="flex items-center gap-3">
      <!-- Status badge -->
      <div class="flex items-center gap-2 bg-[#0d1428] border border-[#162035] rounded-lg px-3 py-2">
        <span id="sim-dot" class="w-2 h-2 rounded-full bg-gray-600 transition-colors"></span>
        <span id="sim-status-text" class="text-xs font-medium text-gray-400">Loading…</span>
      </div>
      <button onclick="simControl('start')"
        class="px-4 py-2 text-xs font-semibold rounded-lg bg-emerald-500/12 text-emerald-400 border border-emerald-500/25 hover:bg-emerald-500/20 transition-all">
        ▶ Start All
      </button>
      <button onclick="simControl('stop')"
        class="px-4 py-2 text-xs font-semibold rounded-lg bg-rose-500/12 text-rose-400 border border-rose-500/25 hover:bg-rose-500/20 transition-all">
        ■ Stop All
      </button>
    </div>
  </div>

  <!-- Stats row -->
  <div class="px-5 pt-4 grid grid-cols-2 lg:grid-cols-4 gap-3 shrink-0">
    <div class="bg-[#0d1428] border border-[#162035] rounded-xl px-4 py-3">
      <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-1">Total Bots</div>
      <div class="text-xl font-bold font-mono text-violet-300" id="sim-total-bots">—</div>
    </div>
    <div class="bg-[#0d1428] border border-[#162035] rounded-xl px-4 py-3">
      <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-1">Active Bots</div>
      <div class="text-xl font-bold font-mono text-emerald-400" id="sim-active-bots">—</div>
    </div>
    <div class="bg-[#0d1428] border border-[#162035] rounded-xl px-4 py-3">
      <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-1">Orders Sent</div>
      <div class="text-xl font-bold font-mono text-white" id="sim-orders">—</div>
    </div>
    <div class="bg-[#0d1428] border border-[#162035] rounded-xl px-4 py-3">
      <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-1">Trades Generated</div>
      <div class="text-xl font-bold font-mono text-amber-400" id="sim-trades">—</div>
    </div>
  </div>

  <!-- Bot grid -->
  <div class="p-5 pt-3">
    <div class="flex items-center justify-between mb-3">
      <span class="text-[10px] text-gray-600 uppercase tracking-widest font-medium">Bots</span>
      <button onclick="loadBots()"
        class="text-[11px] text-gray-500 hover:text-gray-300 transition-colors px-2 py-1 rounded hover:bg-white/[0.04]">
        ↺ Refresh
      </button>
    </div>
    <div id="bots-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
      <div class="bg-[#0d1428] border border-[#162035] rounded-xl p-4 text-xs text-gray-600">Loading bots…</div>
    </div>
  </div>

</Layout>

<script>
  async function loadStatus() {
    try {
      const r = await fetch('/api/simulator/status');
      const d = await r.json();
      const st = d.data ?? d;
      const running = st.running ?? st.isRunning ?? false;

      const dot = document.getElementById('sim-dot')!;
      const statusText = document.getElementById('sim-status-text')!;
      dot.style.background = running ? '#22c55e' : '#ef4444';
      statusText.textContent = running ? 'Running' : 'Stopped';
      (statusText as HTMLElement).style.color = running ? '#22c55e' : '#9ca3af';

      document.getElementById('sim-total-bots')!.textContent  = String(st.totalBots ?? '—');
      document.getElementById('sim-active-bots')!.textContent = String(st.activeBots ?? (running ? st.totalBots : 0) ?? '—');
      document.getElementById('sim-orders')!.textContent = (st.totalOrdersSent ?? st.ordersPlaced ?? 0).toLocaleString();
      document.getElementById('sim-trades')!.textContent = (st.totalTradesGenerated ?? st.trades ?? 0).toLocaleString();
    } catch (_) {}
  }

  async function loadBots() {
    try {
      const r = await fetch('/api/simulator/bots');
      const d = await r.json();
      const bots: any[] = d.data ?? d ?? [];
      const grid = document.getElementById('bots-grid')!;

      if (bots.length === 0) {
        grid.innerHTML = '<div class="col-span-4 text-xs text-gray-600 py-10 text-center">No bots available</div>';
        return;
      }

      const stratColors: Record<string, string> = {
        'MarketMaker':   '#a78bfa',
        'RandomTrader':  '#fbbf24',
        'TrendFollower': '#22c55e',
      };

      grid.innerHTML = bots.map((bot: any) => {
        const running = bot.running ?? bot.isRunning ?? false;
        const rate = typeof bot.successRate === 'number' ? (bot.successRate * 100).toFixed(1) : '—';
        const stratColor = stratColors[bot.strategyType] ?? '#6b7280';

        return `
        <div class="bg-[#0d1428] border border-[#162035] rounded-xl p-4 flex flex-col gap-3 hover:border-violet-500/20 transition-all">
          <div class="flex items-start justify-between">
            <div class="min-w-0">
              <div class="text-xs font-semibold text-gray-200 truncate">${bot.botId}</div>
              <div class="text-[10px] mt-0.5 font-medium" style="color:${stratColor}">${bot.strategyType ?? '—'}</div>
            </div>
            <div class="flex items-center gap-1.5 shrink-0 ml-2">
              <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:${running ? '#22c55e' : '#4b5563'}"></span>
              <span class="text-[10px] font-medium" style="color:${running ? '#22c55e' : '#6b7280'}">${running ? 'Running' : 'Idle'}</span>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-x-3 gap-y-1.5 text-[11px]">
            <div class="text-gray-600">Total Orders</div>
            <div class="text-right text-gray-300 font-mono">${(bot.totalOrders ?? 0).toLocaleString()}</div>
            <div class="text-gray-600">Successful</div>
            <div class="text-right text-emerald-400 font-mono">${(bot.successfulOrders ?? 0).toLocaleString()}</div>
            <div class="text-gray-600">Volume</div>
            <div class="text-right text-gray-300 font-mono">${(bot.totalVolume ?? 0).toLocaleString()}</div>
            <div class="text-gray-600">Success Rate</div>
            <div class="text-right text-amber-400 font-mono">${rate}%</div>
          </div>

          <div class="w-full bg-[#162035] rounded-full h-1 overflow-hidden">
            <div class="h-full rounded-full transition-all duration-700"
              style="width:${rate === '—' ? 0 : parseFloat(rate)}%;background:${running ? '#22c55e' : '#374151'}">
            </div>
          </div>

          <div class="flex gap-2 mt-auto">
            <button onclick="botControl('${bot.botId}','start')"
              ${running ? 'disabled' : ''}
              class="flex-1 py-1.5 text-[10px] font-medium rounded-lg border transition-all ${running ? 'border-[#162035] text-gray-700 cursor-not-allowed' : 'border-emerald-500/25 text-emerald-400 hover:bg-emerald-500/10'}">
              Start
            </button>
            <button onclick="botControl('${bot.botId}','stop')"
              ${!running ? 'disabled' : ''}
              class="flex-1 py-1.5 text-[10px] font-medium rounded-lg border transition-all ${!running ? 'border-[#162035] text-gray-700 cursor-not-allowed' : 'border-rose-500/25 text-rose-400 hover:bg-rose-500/10'}">
              Stop
            </button>
          </div>
        </div>`;
      }).join('');
    } catch (e: any) {
      document.getElementById('bots-grid')!.innerHTML =
        `<div class="col-span-4 text-xs text-rose-400 py-6 text-center">Error loading bots: ${e.message}</div>`;
    }
  }

  (window as any).simControl = async (action: string) => {
    await fetch(`/api/simulator/${action}`, { method: 'POST' });
    setTimeout(() => { loadStatus(); loadBots(); }, 600);
  };

  (window as any).botControl = async (botId: string, action: string) => {
    await fetch(`/api/simulator/bots/${botId}/${action}`, { method: 'POST' });
    setTimeout(() => { loadStatus(); loadBots(); }, 400);
  };

  loadStatus();
  loadBots();
  setInterval(loadStatus, 3000);
  setInterval(loadBots, 5000);
</script>
