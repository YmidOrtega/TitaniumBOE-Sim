---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Simulator" page="simulator">

  <!-- Simulator header card -->
  <div class="bg-[#161b22] border border-[#30363d] rounded p-5 mb-5">
    <div class="flex items-center justify-between flex-wrap gap-4">
      <div class="flex items-center gap-4">
        <div>
          <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Status</div>
          <div class="flex items-center gap-2">
            <span id="sim-dot" class="w-2 h-2 rounded-full bg-gray-600"></span>
            <span id="sim-status-text" class="text-sm font-semibold">Loading…</span>
          </div>
        </div>
        <div class="w-px h-8 bg-[#30363d]"></div>
        <div>
          <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Total Bots</div>
          <div class="text-sm font-semibold text-[#58a6ff]" id="sim-total-bots">—</div>
        </div>
        <div>
          <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Active Bots</div>
          <div class="text-sm font-semibold text-[#3fb950]" id="sim-active-bots">—</div>
        </div>
        <div>
          <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Orders Sent</div>
          <div class="text-sm font-semibold" id="sim-orders">—</div>
        </div>
        <div>
          <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Trades Generated</div>
          <div class="text-sm font-semibold text-[#3fb950]" id="sim-trades">—</div>
        </div>
      </div>

      <div class="flex gap-2">
        <button onclick="simControl('start')"
          class="px-4 py-2 text-xs rounded bg-[#3fb950]/10 text-[#3fb950] border border-[#3fb950]/30 hover:bg-[#3fb950]/20 transition-colors font-medium">
          ▶ Start All
        </button>
        <button onclick="simControl('stop')"
          class="px-4 py-2 text-xs rounded bg-[#f85149]/10 text-[#f85149] border border-[#f85149]/30 hover:bg-[#f85149]/20 transition-colors font-medium">
          ■ Stop All
        </button>
      </div>
    </div>
  </div>

  <!-- Bot grid -->
  <div class="mb-3 flex items-center justify-between">
    <h2 class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Bots</h2>
    <button onclick="loadBots()" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">↺ Refresh</button>
  </div>

  <div id="bots-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
    <div class="bg-[#161b22] border border-[#30363d] rounded p-4 text-xs text-gray-600">Loading bots…</div>
  </div>

</Layout>

<script>
  async function loadStatus() {
    try {
      const r = await fetch('/api/simulator/status');
      const d = await r.json();
      const st = d.data ?? d;
      const running = st.running ?? st.isRunning ?? false;

      const dot = document.getElementById('sim-dot');
      dot.style.background = running ? '#3fb950' : '#f85149';
      document.getElementById('sim-status-text').textContent = running ? 'Running' : 'Stopped';
      document.getElementById('sim-status-text').style.color = running ? '#3fb950' : '#f85149';
      document.getElementById('sim-total-bots').textContent  = st.totalBots     ?? '—';
      document.getElementById('sim-active-bots').textContent = st.activeBots    ?? (running ? st.totalBots : 0) ?? '—';
      document.getElementById('sim-orders').textContent      = (st.totalOrdersSent ?? st.ordersPlaced ?? 0).toLocaleString();
      document.getElementById('sim-trades').textContent      = (st.totalTradesGenerated ?? st.trades ?? 0).toLocaleString();
    } catch (_) {}
  }

  async function loadBots() {
    try {
      const r = await fetch('/api/simulator/bots');
      const d = await r.json();
      const bots = d.data ?? d ?? [];

      const grid = document.getElementById('bots-grid');
      if (bots.length === 0) {
        grid.innerHTML = '<div class="col-span-4 text-xs text-gray-600 py-8 text-center">No bots available</div>';
        return;
      }

      grid.innerHTML = bots.map(bot => {
        const running = bot.running ?? bot.isRunning ?? false;
        const rate    = typeof bot.successRate === 'number' ? (bot.successRate * 100).toFixed(1) : '—';
        const stratColor = {
          'MarketMaker':   '#58a6ff',
          'RandomTrader':  '#d29922',
          'TrendFollower': '#3fb950',
        }[bot.strategyType] ?? '#8b949e';

        return `
        <div class="bg-[#161b22] border border-[#30363d] rounded p-4 flex flex-col gap-3 hover:border-[#58a6ff]/20 transition-colors">
          <div class="flex items-start justify-between">
            <div>
              <div class="text-xs font-semibold text-gray-200 truncate">${bot.botId}</div>
              <div class="text-[10px] mt-0.5 font-medium" style="color:${stratColor}">${bot.strategyType ?? '—'}</div>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full" style="background:${running ? '#3fb950' : '#f85149'}"></span>
              <span class="text-[10px]" style="color:${running ? '#3fb950' : '#6e7681'}">${running ? 'Running' : 'Idle'}</span>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-x-3 gap-y-1 text-[10px]">
            <div class="text-gray-500">Total Orders</div>
            <div class="text-right text-gray-300">${(bot.totalOrders ?? 0).toLocaleString()}</div>
            <div class="text-gray-500">Successful</div>
            <div class="text-right text-[#3fb950]">${(bot.successfulOrders ?? 0).toLocaleString()}</div>
            <div class="text-gray-500">Volume</div>
            <div class="text-right text-gray-300">${(bot.totalVolume ?? 0).toLocaleString()}</div>
            <div class="text-gray-500">Success Rate</div>
            <div class="text-right text-[#d29922]">${rate}%</div>
          </div>

          <!-- Progress bar for success rate -->
          <div class="w-full bg-[#30363d] rounded-full h-0.5 overflow-hidden">
            <div class="h-full rounded-full transition-all" style="width:${rate === '—' ? 0 : parseFloat(rate)}%;background:${running ? '#3fb950' : '#6e7681'}"></div>
          </div>

          <div class="flex gap-2 mt-auto">
            <button onclick="botControl('${bot.botId}','start')"
              ${running ? 'disabled' : ''}
              class="flex-1 py-1 text-[10px] rounded border transition-colors ${running ? 'border-[#30363d] text-gray-600 cursor-not-allowed' : 'border-[#3fb950]/30 text-[#3fb950] hover:bg-[#3fb950]/10'}">
              Start
            </button>
            <button onclick="botControl('${bot.botId}','stop')"
              ${!running ? 'disabled' : ''}
              class="flex-1 py-1 text-[10px] rounded border transition-colors ${!running ? 'border-[#30363d] text-gray-600 cursor-not-allowed' : 'border-[#f85149]/30 text-[#f85149] hover:bg-[#f85149]/10'}">
              Stop
            </button>
          </div>
        </div>`;
      }).join('');
    } catch (e) {
      document.getElementById('bots-grid').innerHTML =
        `<div class="col-span-4 text-xs text-[#f85149] py-4">Error loading bots: ${e.message}</div>`;
    }
  }

  window.simControl = async (action) => {
    await fetch(`/api/simulator/${action}`, { method: 'POST' });
    setTimeout(() => { loadStatus(); loadBots(); }, 600);
  };

  window.botControl = async (botId, action) => {
    await fetch(`/api/simulator/bots/${botId}/${action}`, { method: 'POST' });
    setTimeout(() => { loadStatus(); loadBots(); }, 400);
  };

  loadStatus();
  loadBots();
  setInterval(loadStatus, 3000);
  setInterval(loadBots, 5000);
</script>
