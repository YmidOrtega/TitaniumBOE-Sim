---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Dashboard" page="dashboard">

  <!-- Stats row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
    <div class="bg-[#161b22] border border-[#30363d] rounded p-3">
      <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Status</div>
      <div class="text-sm font-semibold" id="stat-status">—</div>
    </div>
    <div class="bg-[#161b22] border border-[#30363d] rounded p-3">
      <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Active Orders</div>
      <div class="text-sm font-semibold text-[#58a6ff]" id="stat-orders">—</div>
    </div>
    <div class="bg-[#161b22] border border-[#30363d] rounded p-3">
      <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Total Matches</div>
      <div class="text-sm font-semibold text-[#3fb950]" id="stat-matches">—</div>
    </div>
    <div class="bg-[#161b22] border border-[#30363d] rounded p-3">
      <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Simulator</div>
      <div class="text-sm font-semibold" id="stat-sim">—</div>
    </div>
  </div>

  <!-- Main grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

    <!-- Trade feed (2/3 width) -->
    <div class="lg:col-span-2 bg-[#161b22] border border-[#30363d] rounded overflow-hidden">
      <div class="flex items-center justify-between px-4 py-2.5 border-b border-[#30363d]">
        <span class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Live Trade Feed</span>
        <span class="text-[10px] text-gray-500" id="trade-count">0 trades</span>
      </div>
      <div class="overflow-y-auto" style="height:420px">
        <table class="w-full text-xs">
          <thead class="sticky top-0 bg-[#161b22]">
            <tr class="text-[10px] text-gray-500 uppercase">
              <th class="px-4 py-2 text-left">Time</th>
              <th class="px-4 py-2 text-left">Symbol</th>
              <th class="px-4 py-2 text-right">Price</th>
              <th class="px-4 py-2 text-right">Qty</th>
              <th class="px-4 py-2 text-left">Buyer</th>
              <th class="px-4 py-2 text-left">Seller</th>
            </tr>
          </thead>
          <tbody id="trade-tbody" class="divide-y divide-[#30363d]/50">
            <tr><td colspan="6" class="px-4 py-8 text-center text-gray-600 text-xs">Waiting for trades…</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Right column -->
    <div class="flex flex-col gap-4">

      <!-- Server info -->
      <div class="bg-[#161b22] border border-[#30363d] rounded p-4">
        <div class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-3">Server</div>
        <div class="space-y-2 text-xs">
          <div class="flex justify-between">
            <span class="text-gray-500">BOE Protocol</span>
            <span class="text-[#58a6ff]">:8080</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">REST API</span>
            <span class="text-[#58a6ff]">:8081</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">WebSocket</span>
            <span class="text-[#58a6ff]">/ws/feed</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">API Docs</span>
            <a href="/api/docs" target="_blank" class="text-[#58a6ff] hover:underline">/api/docs</a>
          </div>
        </div>
      </div>

      <!-- Simulator control -->
      <div class="bg-[#161b22] border border-[#30363d] rounded p-4">
        <div class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-3">Market Simulator</div>
        <div class="flex items-center justify-between mb-3">
          <div>
            <div class="text-xs text-gray-500 mb-0.5">State</div>
            <div class="text-sm font-semibold" id="sim-state">—</div>
          </div>
          <div>
            <div class="text-xs text-gray-500 mb-0.5">Bots</div>
            <div class="text-sm font-semibold text-[#58a6ff]" id="sim-bots">—</div>
          </div>
          <div>
            <div class="text-xs text-gray-500 mb-0.5">Orders</div>
            <div class="text-sm font-semibold text-[#3fb950]" id="sim-orders-sent">—</div>
          </div>
        </div>
        <div class="flex gap-2">
          <button id="btn-start" onclick="simAction('start')"
            class="flex-1 py-1.5 text-xs rounded bg-[#3fb950]/10 text-[#3fb950] border border-[#3fb950]/30 hover:bg-[#3fb950]/20 transition-colors">
            Start
          </button>
          <button id="btn-stop" onclick="simAction('stop')"
            class="flex-1 py-1.5 text-xs rounded bg-[#f85149]/10 text-[#f85149] border border-[#f85149]/30 hover:bg-[#f85149]/20 transition-colors">
            Stop
          </button>
        </div>
      </div>

      <!-- Symbols -->
      <div class="bg-[#161b22] border border-[#30363d] rounded p-4">
        <div class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-3">Symbols</div>
        <div id="symbols-grid" class="grid grid-cols-4 gap-1.5 text-[10px]">
          <span class="text-gray-600">loading…</span>
        </div>
      </div>

    </div>
  </div>

</Layout>

<script>
  const SYMBOLS = ['AAPL','MSFT','GOOGL','GOOG','AMZN','META','TSLA','NFLX'];
  let tradeCount = 0;
  let prevLastPrice = {};

  // Fetch health
  async function fetchHealth() {
    try {
      const r = await fetch('/api/health');
      const d = await r.json();
      const el = document.getElementById('stat-status');
      el.textContent = d.status ?? '—';
      el.style.color = d.status === 'healthy' ? '#3fb950' : '#f85149';
      document.getElementById('stat-orders').textContent  = d.activeOrders ?? '—';
      document.getElementById('stat-matches').textContent = d.totalMatches  ?? '—';
    } catch (_) {}
  }

  // Fetch simulator
  async function fetchSim() {
    try {
      const r = await fetch('/api/simulator/status');
      const d = await r.json();
      const st = d.data ?? d;
      const running = st.running ?? st.isRunning ?? false;
      const el = document.getElementById('sim-state');
      el.textContent = running ? 'Running' : 'Stopped';
      el.style.color = running ? '#3fb950' : '#f85149';
      document.getElementById('stat-sim').textContent = running ? 'Running' : 'Stopped';
      document.getElementById('stat-sim').style.color = running ? '#3fb950' : '#f85149';
      document.getElementById('sim-bots').textContent       = st.totalBots ?? st.activeBots ?? '—';
      document.getElementById('sim-orders-sent').textContent = st.totalOrdersSent ?? st.ordersPlaced ?? '—';
    } catch (_) {}
  }

  // Fetch symbols
  async function fetchSymbols() {
    try {
      const r = await fetch('/api/symbols');
      const d = await r.json();
      const syms = d.data ?? d ?? SYMBOLS;
      const grid = document.getElementById('symbols-grid');
      grid.innerHTML = syms.map(s =>
        `<a href="/orders?symbol=${s}" class="px-1.5 py-1 rounded bg-[#30363d]/40 text-gray-300 hover:text-[#58a6ff] hover:bg-[#58a6ff]/10 text-center transition-colors cursor-pointer">${s}</a>`
      ).join('');
    } catch (_) {
      document.getElementById('symbols-grid').innerHTML =
        SYMBOLS.map(s => `<a href="/orders?symbol=${s}" class="px-1.5 py-1 rounded bg-[#30363d]/40 text-gray-300 hover:text-[#58a6ff] text-center">${s}</a>`).join('');
    }
  }

  // Simulator control
  window.simAction = async (action) => {
    await fetch(`/api/simulator/${action}`, { method: 'POST' });
    setTimeout(fetchSim, 500);
  };

  // Trade row
  function addTrade(msg) {
    const tbody = document.getElementById('trade-tbody');
    if (tbody.children.length === 1 && tbody.children[0].children.length === 1) {
      tbody.innerHTML = '';
    }

    const price = parseFloat(msg.price ?? 0);
    const prev  = prevLastPrice[msg.symbol] ?? price;
    const color = price > prev ? '#3fb950' : price < prev ? '#f85149' : '#e6edf3';
    prevLastPrice[msg.symbol] = price;

    const t = new Date(msg.timestamp ?? msg.executionTime ?? Date.now());
    const time = t.toLocaleTimeString('en-US', { hour12: false });

    const row = document.createElement('tr');
    row.className = 'hover:bg-white/[0.02] transition-colors';
    row.innerHTML = `
      <td class="px-4 py-1.5 text-gray-500">${time}</td>
      <td class="px-4 py-1.5 text-[#58a6ff] font-medium">${msg.symbol ?? '—'}</td>
      <td class="px-4 py-1.5 text-right font-mono font-medium" style="color:${color}">${price.toFixed(4)}</td>
      <td class="px-4 py-1.5 text-right text-gray-300">${msg.quantity ?? msg.qty ?? '—'}</td>
      <td class="px-4 py-1.5 text-gray-400">${msg.buyUsername ?? '—'}</td>
      <td class="px-4 py-1.5 text-gray-400">${msg.sellUsername ?? '—'}</td>
    `;
    tbody.insertBefore(row, tbody.firstChild);
    if (tbody.children.length > 200) tbody.removeChild(tbody.lastChild);

    tradeCount++;
    document.getElementById('trade-count').textContent = `${tradeCount} trade${tradeCount !== 1 ? 's' : ''}`;
  }

  // Init
  fetchHealth();
  fetchSim();
  fetchSymbols();

  setInterval(fetchHealth, 5000);
  setInterval(fetchSim, 3000);

  // Subscribe to all symbols for trade feed
  window.wsAddHandler({
    onopen() {
      SYMBOLS.forEach(s => window.wsSubscribe(s));
    },
    onmessage(msg) {
      if (msg.type === 'trade') addTrade(msg);
    }
  });
</script>
