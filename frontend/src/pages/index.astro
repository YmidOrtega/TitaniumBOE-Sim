---
import Layout from '../layouts/Layout.astro';
const SYMBOLS = ['AAPL','MSFT','GOOGL','GOOG','AMZN','META','TSLA','NFLX'];
const MARKET_SYMS = ['AAPL','MSFT','GOOGL','AMZN','META'];
---
<Layout title="Dashboard" page="dashboard">

  <!-- Main scroll area -->
  <div class="p-5 space-y-4">

    <!-- Welcome row + action buttons -->
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-lg font-semibold text-white mb-0.5">
          Welcome back, <span id="trader-name">Trader</span> 👋
        </h1>
        <p class="text-[11px] text-gray-500">Real-time overview of the Cboe Titanium BOE protocol simulation.</p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <button id="btn-demo-mode" onclick="toggleDemoMode()"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] font-semibold border transition-all">
          <span class="w-1.5 h-1.5 rounded-full" id="demo-dot"></span>
          <span id="demo-label">Demo Mode</span>
        </button>
        <button id="btn-start-bots" onclick="simToggle()"
          class="px-3 py-1.5 rounded-lg text-[11px] font-semibold bg-emerald-500/15 text-emerald-400 border border-emerald-500/25 hover:bg-emerald-500/25 transition-all">
          START BOTS
        </button>
      </div>
    </div>

    <!-- Stats ticker row -->
    <div class="flex items-center gap-0 bg-[#0d1428] border border-[#162035] rounded-xl overflow-hidden divide-x divide-[#162035]">
      <div class="flex-1 px-4 py-3 min-w-0">
        <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-1">Total P&L</div>
        <div class="text-sm font-bold font-mono text-emerald-400" id="hdr-pnl">—</div>
      </div>
      <div class="flex-1 px-4 py-3 min-w-0">
        <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-1">Natural Vol</div>
        <div class="flex items-baseline gap-1.5">
          <span class="text-sm font-bold font-mono text-white" id="hdr-vol">—</span>
        </div>
      </div>
      <div class="flex-1 px-4 py-3 min-w-0">
        <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-1">Total Trades</div>
        <div class="flex items-baseline gap-1.5">
          <span class="text-sm font-bold font-mono text-white" id="hdr-trades">—</span>
          <span class="text-[10px] font-mono text-emerald-400" id="hdr-trades-chg"></span>
        </div>
      </div>
      <div class="flex-1 px-4 py-3 min-w-0">
        <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-1">Active Orders</div>
        <div class="flex items-baseline gap-1.5">
          <span class="text-sm font-bold font-mono text-white" id="hdr-orders">—</span>
          <span class="text-[10px] font-mono" id="hdr-orders-chg"></span>
        </div>
      </div>
      <div class="flex-1 px-4 py-3 min-w-0">
        <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-1">Connected</div>
        <div class="text-sm font-bold font-mono text-violet-300" id="hdr-clients">1</div>
      </div>
    </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-[#0d1428] border border-[#162035] rounded-xl p-4">
          <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-2">Total P&L</div>
          <div class="text-2xl font-bold text-white font-mono" id="kpi-pnl">—</div>
          <div class="text-[11px] text-gray-600 mt-1">Requires auth</div>
        </div>
        <div class="bg-[#0d1428] border border-[#162035] rounded-xl p-4">
          <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-2">Active Orders</div>
          <div class="text-2xl font-bold text-white font-mono" id="kpi-orders">—</div>
          <div class="text-[11px] text-emerald-400 mt-1 font-mono" id="kpi-orders-sub">Live</div>
        </div>
        <div class="bg-[#0d1428] border border-[#162035] rounded-xl p-4">
          <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-2">Total Trades</div>
          <div class="text-2xl font-bold text-white font-mono" id="kpi-trades">—</div>
          <div class="text-[11px] text-gray-600 mt-1">All symbols</div>
        </div>
        <div class="bg-[#0d1428] border border-[#162035] rounded-xl p-4">
          <div class="text-[10px] text-gray-600 uppercase tracking-widest font-medium mb-2">Best Spread</div>
          <div class="text-2xl font-bold text-white font-mono" id="kpi-spread">—</div>
          <div class="text-[11px] text-violet-400 mt-1" id="kpi-spread-sym">AAPL</div>
        </div>
      </div>

    <!-- Middle row: Market | Order Book | Health -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

      <!-- Market Overview -->
      <div class="bg-[#0d1428] border border-[#162035] rounded-xl overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-[#162035]">
          <span class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Market Overview</span>
          <span class="text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded-full">Live</span>
        </div>
        <table class="w-full text-xs">
          <thead>
            <tr class="text-[10px] text-gray-600 uppercase tracking-wider border-b border-[#162035]/60">
              <th class="px-4 py-2 text-left font-medium">Symbol</th>
              <th class="px-4 py-2 text-right font-medium">Last</th>
              <th class="px-4 py-2 text-right font-medium">Change</th>
              <th class="px-4 py-2 text-right font-medium">Vol</th>
              <th class="px-4 py-2 text-right font-medium">Trades</th>
            </tr>
          </thead>
          <tbody id="market-tbody" class="divide-y divide-[#162035]/50">
            {MARKET_SYMS.map(s => (
              <tr data-sym={s} class="hover:bg-white/[0.025] transition-colors cursor-pointer" onclick={`selectOBSymbol('${s}')`}>
                <td class="px-4 py-2.5 font-semibold text-violet-300">{s}</td>
                <td class="px-4 py-2.5 text-right font-mono text-gray-400 mkt-last">—</td>
                <td class="px-4 py-2.5 text-right font-mono mkt-chg text-gray-600">—</td>
                <td class="px-4 py-2.5 text-right text-gray-600 mkt-vol">—</td>
                <td class="px-4 py-2.5 text-right text-gray-600 mkt-cnt">—</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Order Book compact -->
      <div class="bg-[#0d1428] border border-[#162035] rounded-xl overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-[#162035]">
          <span class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Order Book</span>
          <select id="ob-sym-select" onchange="selectOBSymbol(this.value)"
            class="text-[11px] bg-[#0a1020] border border-[#1e2a45] rounded-lg px-2 py-1 text-violet-300 outline-none cursor-pointer">
            {SYMBOLS.map(s => <option value={s}>{s}</option>)}
          </select>
        </div>
        <!-- Asks -->
        <div class="px-3 pt-3 space-y-0.5" id="ob-asks" style="min-height:88px">
          <div class="text-[11px] text-gray-600 text-center py-4">Waiting…</div>
        </div>
        <!-- Spread -->
        <div class="mx-3 my-1 flex items-center justify-between bg-[#080d1a] rounded-lg px-3 py-1.5 text-[11px]">
          <span class="text-gray-600">Spread</span>
          <span class="font-mono font-semibold text-white" id="ob-spread">—</span>
          <span class="text-gray-600 font-mono" id="ob-spread-pct"></span>
        </div>
        <!-- Bids -->
        <div class="px-3 pb-3 space-y-0.5" id="ob-bids" style="min-height:88px">
          <div class="text-[11px] text-gray-600 text-center py-4">Waiting…</div>
        </div>
      </div>

      <!-- System Health -->
      <div class="bg-[#0d1428] border border-[#162035] rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-[#162035]">
          <span class="text-xs font-semibold text-gray-300 uppercase tracking-wider">System Health</span>
        </div>
        <div class="flex flex-col items-center pt-5 pb-3">
          <!-- SVG Gauge -->
          <div class="relative w-28 h-28 mb-4">
            <svg class="w-full h-full" viewBox="0 0 120 120" style="transform:rotate(-90deg)">
              <circle cx="60" cy="60" r="48" fill="none" stroke="#1e2a45" stroke-width="9"/>
              <circle cx="60" cy="60" r="48" fill="none" stroke="url(#hGrad)" stroke-width="9"
                stroke-linecap="round" stroke-dasharray="301.59" id="health-arc"
                stroke-dashoffset="301.59" style="transition:stroke-dashoffset 1s ease"/>
              <defs>
                <linearGradient id="hGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#7c3aed"/>
                  <stop offset="100%" stop-color="#c4b5fd"/>
                </linearGradient>
              </defs>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-2xl font-bold font-mono" id="health-pct">—</span>
              <span class="text-[10px] text-gray-600">Health</span>
            </div>
          </div>
          <!-- Metrics -->
          <div class="w-full px-5 space-y-2 text-xs">
            <div class="flex justify-between">
              <span class="text-gray-600">Status</span>
              <span class="font-medium" id="h-status">—</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Active Orders</span>
              <span class="text-gray-300 font-mono" id="h-orders">—</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Total Matches</span>
              <span class="text-gray-300 font-mono" id="h-matches">—</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Simulator</span>
              <span class="font-medium" id="h-sim">—</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Running Bots</span>
              <span class="text-gray-300 font-mono" id="h-bots">—</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom row: Live Trades | Positions | Bots + Events -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

      <!-- Live Trades -->
      <div class="bg-[#0d1428] border border-[#162035] rounded-xl overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-[#162035]">
          <span class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Live Trades</span>
          <span class="text-[10px] text-gray-600 font-mono" id="live-count">0 trades</span>
        </div>
        <div class="overflow-y-auto" style="height:210px">
          <table class="w-full text-xs">
            <thead class="sticky top-0 bg-[#0d1428]">
              <tr class="text-[10px] text-gray-600 uppercase tracking-wider border-b border-[#162035]/50">
                <th class="px-3 py-2 text-left font-medium">Time</th>
                <th class="px-3 py-2 text-left font-medium">Sym</th>
                <th class="px-3 py-2 text-right font-medium">Price</th>
                <th class="px-3 py-2 text-right font-medium">Qty</th>
              </tr>
            </thead>
            <tbody id="live-tbody" class="divide-y divide-[#162035]/40">
              <tr><td colspan="4" class="px-3 py-8 text-center text-gray-600">Waiting for trades…</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Your Positions -->
      <div class="bg-[#0d1428] border border-[#162035] rounded-xl overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-[#162035]">
          <span class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Your Positions</span>
          <a href="/trades" class="text-[10px] text-violet-400 hover:text-violet-300 transition-colors">View all →</a>
        </div>
        <div class="overflow-y-auto" style="height:210px">
          <table class="w-full text-xs">
            <thead class="sticky top-0 bg-[#0d1428]">
              <tr class="text-[10px] text-gray-600 uppercase tracking-wider border-b border-[#162035]/50">
                <th class="px-3 py-2 text-left font-medium">Symbol</th>
                <th class="px-3 py-2 text-right font-medium">Qty</th>
                <th class="px-3 py-2 text-right font-medium">Avg Px</th>
                <th class="px-3 py-2 text-right font-medium">P&L</th>
              </tr>
            </thead>
            <tbody id="positions-tbody" class="divide-y divide-[#162035]/40">
              <tr><td colspan="4" class="px-3 py-8 text-center text-gray-600">Login required</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Bots + Events -->
      <div class="flex flex-col gap-3">
        <!-- Trading Bots -->
        <div class="bg-[#0d1428] border border-[#162035] rounded-xl overflow-hidden">
          <div class="flex items-center justify-between px-4 py-3 border-b border-[#162035]">
            <span class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Trading Bots</span>
            <button onclick="simToggle()"
              class="text-[10px] px-2.5 py-1 rounded-lg bg-violet-600/15 text-violet-300 border border-violet-500/20 hover:bg-violet-600/25 transition-all font-medium">
              MANAGE BOTS
            </button>
          </div>
          <div class="p-3 space-y-2" id="bots-panel">
            {['Market Maker','Trend Follower','Random Trader'].map(name => (
              <div class="flex items-center justify-between text-xs">
                <span class="text-gray-400">{name}</span>
                <span class="bot-badge px-2 py-0.5 rounded-full text-[10px] font-medium bg-gray-700/30 text-gray-500">Idle</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Recent Events -->
        <div class="bg-[#0d1428] border border-[#162035] rounded-xl overflow-hidden flex-1">
          <div class="px-4 py-3 border-b border-[#162035]">
            <span class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Recent Events</span>
          </div>
          <div id="events-list" class="p-3 space-y-1.5 overflow-y-auto" style="max-height:120px">
            <div class="text-[11px] text-gray-600">Waiting…</div>
          </div>
        </div>
      </div>

    </div>
  </div>

</Layout>

<script>
  const ALL_SYMBOLS = ['AAPL','MSFT','GOOGL','GOOG','AMZN','META','TSLA','NFLX'];
  const MARKET_SYMS = ['AAPL','MSFT','GOOGL','AMZN','META'];

  let liveTradeCount = 0;
  let prevPrice: Record<string, number> = {};
  let marketData: Record<string, any> = {};
  let obSymbol = 'AAPL';
  let recentEvents: { time: string; text: string }[] = [];
  let prevHealthOrders = 0;
  let prevHealthTrades = 0;
  let simRunning = false;

  MARKET_SYMS.forEach(s => { marketData[s] = { last: 0, prev: 0, vol: 0, cnt: 0 }; });

  // ── Health ────────────────────────────────────────────────────────────────
  async function fetchHealth() {
    try {
      const r = await fetch('/api/health');
      const d = await r.json();

      const activeOrders = d.activeOrders ?? 0;
      const totalMatches = d.totalMatches ?? 0;
      const healthy = d.status === 'healthy';
      const pct = healthy ? 98 : 30;

      // Header
      document.getElementById('hdr-orders')!.textContent = activeOrders.toLocaleString();

      const ordChg = document.getElementById('hdr-orders-chg')!;
      if (prevHealthOrders > 0) {
        const delta = activeOrders - prevHealthOrders;
        ordChg.textContent = (delta >= 0 ? '+' : '') + delta.toLocaleString();
        (ordChg as HTMLElement).style.color = delta >= 0 ? '#22c55e' : '#f87171';
      }
      prevHealthOrders = activeOrders;

      // KPI cards
      document.getElementById('kpi-orders')!.textContent = activeOrders.toLocaleString();
      document.getElementById('h-orders')!.textContent = activeOrders.toLocaleString();
      document.getElementById('h-matches')!.textContent = totalMatches.toLocaleString();

      // Gauge
      const arc = document.getElementById('health-arc')!;
      const circumference = 301.59;
      (arc as any).style.strokeDashoffset = circumference - (circumference * pct / 100);
      const pctEl = document.getElementById('health-pct')!;
      pctEl.textContent = pct + '%';
      (pctEl as HTMLElement).style.color = healthy ? '#a78bfa' : '#f87171';

      const statusEl = document.getElementById('h-status')!;
      statusEl.textContent = d.status ?? '—';
      (statusEl as HTMLElement).style.color = healthy ? '#22c55e' : '#ef4444';
    } catch (_) {}
  }

  // ── Simulator ────────────────────────────────────────────────────────────
  async function fetchSim() {
    try {
      const r = await fetch('/api/simulator/status');
      const d = await r.json();
      const st = d.data ?? d;
      simRunning = st.running ?? st.isRunning ?? false;
      const botCount = st.activeBots ?? st.totalBots ?? 3;

      document.getElementById('h-sim')!.textContent = simRunning ? 'Running' : 'Stopped';
      (document.getElementById('h-sim') as HTMLElement).style.color = simRunning ? '#22c55e' : '#9ca3af';
      document.getElementById('h-bots')!.textContent = String(botCount);

      // Bots panel badges
      document.querySelectorAll('.bot-badge').forEach(b => {
        (b as HTMLElement).textContent = simRunning ? 'Active' : 'Idle';
        (b as HTMLElement).style.background = simRunning ? 'rgba(34,197,94,0.12)' : 'rgba(107,114,128,0.15)';
        (b as HTMLElement).style.color = simRunning ? '#22c55e' : '#6b7280';
      });

      // Start bots button
      const btn = document.getElementById('btn-start-bots')!;
      if (simRunning) {
        btn.textContent = 'STOP BOTS';
        btn.style.background = 'rgba(239,68,68,0.12)';
        btn.style.color = '#f87171';
        btn.style.borderColor = 'rgba(239,68,68,0.2)';
      } else {
        btn.textContent = 'START BOTS';
        btn.style.background = 'rgba(34,197,94,0.12)';
        btn.style.color = '#22c55e';
        btn.style.borderColor = 'rgba(34,197,94,0.2)';
      }
    } catch (_) {}
  }

  // ── Sim toggle ────────────────────────────────────────────────────────────
  (window as any).simToggle = async () => {
    const action = simRunning ? 'stop' : 'start';
    await fetch(`/api/simulator/${action}`, { method: 'POST' });
    addEvent(`Simulator ${action} requested`);
    setTimeout(fetchSim, 500);
  };

  // ── Symbol data ───────────────────────────────────────────────────────────
  async function fetchAllSymbols() {
    try {
      const r = await fetch('/api/symbols');
      if (!r.ok) return;
      const raw = await r.json();
      const list: any[] = raw.data ?? raw;

      for (const d of list) {
        const sym = d.symbol;
        if (!MARKET_SYMS.includes(sym) && !ALL_SYMBOLS.includes(sym)) continue;

        const last = parseFloat(d.lastPrice ?? d.lastTradePrice ?? d.bestBid ?? 0);
        if (last > 0 && marketData[sym]) {
          marketData[sym].prev = marketData[sym].last || last;
          marketData[sym].last = last;
        }

        const bestBid = d.bestBid ? parseFloat(d.bestBid) : null;
        const bestAsk = d.bestAsk ? parseFloat(d.bestAsk) : null;

        if (bestBid && bestAsk && sym === 'AAPL') {
          const spread = (bestAsk - bestBid).toFixed(4);
          document.getElementById('kpi-spread')!.textContent = spread;
        }

        updateMarketRow(sym);
      }
    } catch (_) {}
  }

  async function fetchSymbolData(sym: string) {
    await fetchAllSymbols();
  }

  function updateMarketRow(sym: string) {
    const row = document.querySelector<HTMLTableRowElement>(`tr[data-sym="${sym}"]`);
    if (!row) return;
    const md = marketData[sym];
    if (!md?.last) return;

    const last = md.last as number;
    const prev = (md.prev as number) || last;
    const chgPct = prev > 0 ? ((last - prev) / prev * 100) : 0;
    const up = chgPct >= 0;
    const color = up ? '#22c55e' : '#f87171';

    const lastEl = row.querySelector('.mkt-last') as HTMLElement;
    lastEl.textContent = last.toFixed(2);
    lastEl.style.color = '#e5e7eb';

    const chgEl = row.querySelector('.mkt-chg') as HTMLElement;
    chgEl.textContent = (up ? '▲ +' : '▼ ') + Math.abs(chgPct).toFixed(2) + '%';
    chgEl.style.color = color;

    (row.querySelector('.mkt-vol') as HTMLElement).textContent = ((md.vol as number) || 0).toLocaleString();
    (row.querySelector('.mkt-cnt') as HTMLElement).textContent = String((md.cnt as number) || 0);
  }

  // ── Order Book ───────────────────────────────────────────────────────────
  function renderOB(msg: any) {
    if (msg.symbol !== obSymbol) return;

    const bids = (msg.bids ?? []).slice(0, 6) as any[];
    const asks = (msg.asks ?? []).slice(-6) as any[];
    const maxQ = Math.max(...bids.map((l: any) => l.quantity ?? 0), ...asks.map((l: any) => l.quantity ?? 0), 1);

    const asksEl = document.getElementById('ob-asks')!;
    if (asks.length === 0) {
      asksEl.innerHTML = '<div class="text-[11px] text-gray-600 text-center py-4">No asks</div>';
    } else {
      asksEl.innerHTML = [...asks].reverse().map((l: any) => {
        const pct = ((l.quantity ?? 0) / maxQ * 100).toFixed(0);
        return `<div class="flex items-center justify-between text-[11px] py-0.5 px-1 relative rounded overflow-hidden">
          <div class="absolute inset-0 bg-rose-500/8 rounded" style="width:${pct}%;right:0;left:auto"></div>
          <span class="font-mono text-rose-400 z-10">${parseFloat(l.price).toFixed(2)}</span>
          <span class="text-gray-600 z-10 font-mono">${l.quantity}</span>
        </div>`;
      }).join('');
    }

    const bidsEl = document.getElementById('ob-bids')!;
    if (bids.length === 0) {
      bidsEl.innerHTML = '<div class="text-[11px] text-gray-600 text-center py-4">No bids</div>';
    } else {
      bidsEl.innerHTML = bids.map((l: any) => {
        const pct = ((l.quantity ?? 0) / maxQ * 100).toFixed(0);
        return `<div class="flex items-center justify-between text-[11px] py-0.5 px-1 relative rounded overflow-hidden">
          <div class="absolute inset-0 bg-emerald-500/8 rounded" style="width:${pct}%"></div>
          <span class="font-mono text-emerald-400 z-10">${parseFloat(l.price).toFixed(2)}</span>
          <span class="text-gray-600 z-10 font-mono">${l.quantity}</span>
        </div>`;
      }).join('');
    }

    const bestBid = bids.length ? parseFloat(bids[0].price) : null;
    const bestAsk = asks.length ? parseFloat(asks[asks.length - 1].price) : null;
    if (bestBid && bestAsk) {
      const spread = (bestAsk - bestBid).toFixed(4);
      const pct = ((bestAsk - bestBid) / bestAsk * 100).toFixed(2);
      document.getElementById('ob-spread')!.textContent = spread;
      document.getElementById('ob-spread-pct')!.textContent = `(${pct}%)`;
      document.getElementById('kpi-spread')!.textContent = spread;
      document.getElementById('kpi-spread-sym')!.textContent = obSymbol;
    }
  }

  (window as any).selectOBSymbol = (sym: string) => {
    if (obSymbol !== sym) {
      (window as any).wsUnsubscribe(obSymbol);
    }
    obSymbol = sym;
    const sel = document.getElementById('ob-sym-select') as HTMLSelectElement;
    if (sel) sel.value = sym;
    (window as any).wsSubscribe(sym);
    fetchSymbolData(sym);
    document.getElementById('kpi-spread-sym')!.textContent = sym;
  };

  // ── Live Trades ──────────────────────────────────────────────────────────
  function addLiveTrade(msg: any) {
    const tbody = document.getElementById('live-tbody')!;
    if (tbody.querySelector('td[colspan]')) tbody.innerHTML = '';

    const price = parseFloat(msg.price ?? 0);
    const prev = prevPrice[msg.symbol] ?? price;
    const color = price > prev ? '#22c55e' : price < prev ? '#f87171' : '#d1d5db';
    prevPrice[msg.symbol] = price;

    const time = new Date(msg.timestamp ?? Date.now()).toLocaleTimeString('en-US', { hour12: false });

    const row = document.createElement('tr');
    row.className = 'hover:bg-white/[0.02] transition-colors';
    row.innerHTML = `
      <td class="px-3 py-1.5 text-gray-600 font-mono">${time}</td>
      <td class="px-3 py-1.5 font-semibold text-violet-300">${msg.symbol ?? '—'}</td>
      <td class="px-3 py-1.5 text-right font-mono font-medium" style="color:${color}">${price.toFixed(2)}</td>
      <td class="px-3 py-1.5 text-right text-gray-400 font-mono">${msg.quantity ?? '—'}</td>
    `;
    tbody.insertBefore(row, tbody.firstChild);
    if (tbody.children.length > 60) tbody.removeChild(tbody.lastChild!);

    liveTradeCount++;
    document.getElementById('live-count')!.textContent = `${liveTradeCount.toLocaleString()} trades`;
    document.getElementById('hdr-trades')!.textContent = liveTradeCount.toLocaleString();
    document.getElementById('kpi-trades')!.textContent = liveTradeCount.toLocaleString();

    // Update market data
    if (marketData[msg.symbol]) {
      marketData[msg.symbol].cnt++;
      marketData[msg.symbol].vol += msg.quantity ?? 0;
      const lp = parseFloat(msg.price ?? 0);
      if (lp > 0) {
        marketData[msg.symbol].prev = marketData[msg.symbol].last || lp;
        marketData[msg.symbol].last = lp;
      }
      updateMarketRow(msg.symbol);
    }

    addEvent(`${msg.symbol} ${msg.quantity ?? ''}@${price.toFixed(2)} ${msg.buyUsername ? '· ' + msg.buyUsername : ''}`);
  }

  // ── Events ────────────────────────────────────────────────────────────────
  function addEvent(text: string) {
    const time = new Date().toLocaleTimeString('en-US', { hour12: false });
    recentEvents.unshift({ time, text });
    if (recentEvents.length > 12) recentEvents.pop();
    const el = document.getElementById('events-list')!;
    el.innerHTML = recentEvents.map(e =>
      `<div class="flex gap-2 text-[11px] leading-snug">
        <span class="text-gray-700 font-mono shrink-0">${e.time}</span>
        <span class="text-gray-400">${e.text}</span>
      </div>`
    ).join('');
  }

  // ── Trader name ──────────────────────────────────────────────────────────
  function detectTraderName() {
    const stored = localStorage.getItem('traderName');
    if (stored) {
      document.getElementById('trader-name')!.textContent = stored;
      return;
    }
    // Try demo credentials — if they work, we're in demo mode and user is TRD1
    fetch('/api/positions', {
      headers: { 'Authorization': 'Basic ' + btoa('TRD1:Pass1234!') }
    }).then(r => {
      if (r.ok) {
        document.getElementById('trader-name')!.textContent = 'TRD1';
        localStorage.setItem('traderName', 'TRD1');
        setDemoUI(true);
      }
    }).catch(() => {});
  }

  // ── Demo Mode ────────────────────────────────────────────────────────────
  let isDemoMode = false;

  function setDemoUI(demo: boolean) {
    isDemoMode = demo;
    const btn = document.getElementById('btn-demo-mode')!;
    const dot = document.getElementById('demo-dot')!;
    const lbl = document.getElementById('demo-label')!;
    if (demo) {
      btn.style.cssText = 'background:rgba(251,191,36,0.12);color:#fbbf24;border-color:rgba(251,191,36,0.25)';
      dot.style.background = '#fbbf24';
      lbl.textContent = 'Demo Mode';
    } else {
      btn.style.cssText = 'background:rgba(139,92,246,0.12);color:#a78bfa;border-color:rgba(139,92,246,0.25)';
      dot.style.background = '#22c55e';
      lbl.textContent = 'Live Mode';
    }
  }

  async function detectDemoMode() {
    try {
      // Try demo credentials — if 200, we're in demo mode
      const r = await fetch('/api/positions', {
        headers: { 'Authorization': 'Basic ' + btoa('TRD1:Pass1234!') }
      });
      setDemoUI(r.ok);
    } catch (_) {
      setDemoUI(false);
    }
  }

  (window as any).toggleDemoMode = async () => {
    // In a real scenario this would hit an admin endpoint
    // For now we toggle the visual state and notify
    const next = !isDemoMode;
    setDemoUI(next);
    if (next) {
      // Try to use demo credentials
      const r = await fetch('/api/positions', {
        headers: { 'Authorization': 'Basic ' + btoa('TRD1:Pass1234!') }
      });
      if (!r.ok) {
        setDemoUI(false);
        alert('Demo Mode requires DEMO_MODE=true on the server.');
      } else {
        document.getElementById('trader-name')!.textContent = 'TRD1';
        localStorage.setItem('traderName', 'TRD1');
      }
    } else {
      localStorage.removeItem('traderName');
      document.getElementById('trader-name')!.textContent = 'Trader';
    }
  };

  // ── Init ──────────────────────────────────────────────────────────────────
  detectTraderName();
  detectDemoMode();
  fetchHealth();
  fetchSim();
  fetchAllSymbols();

  setInterval(fetchHealth, 2000);
  setInterval(fetchSim, 3000);
  setInterval(fetchAllSymbols, 10000);

  // Deferred to handle dev-mode script-loading order (Layout may define wsAddHandler after this module)
  function registerWsHandler() {
    if (typeof (window as any).wsAddHandler === 'function') {
      (window as any).wsAddHandler({
        onopen() {
          ALL_SYMBOLS.forEach((s: string) => (window as any).wsSubscribe(s));
          addEvent('WebSocket connected');
        },
        onmessage(msg: any) {
          if (msg.type === 'trade') addLiveTrade(msg);
          if (msg.type === 'orderbook') renderOB(msg);
        }
      });
    } else {
      setTimeout(registerWsHandler, 50);
    }
  }
  setTimeout(registerWsHandler, 0);
</script>
